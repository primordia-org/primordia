# Dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# Next.js build output
/.next/
/out/

# Production build
/build

# Environment files — never commit secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Debug logs
bun-debug.log*
bun-error.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts


# Local SQLite database (passkey auth — local dev only)
*.db
*.db-shm
*.db-wal

# Uploaded attachments copied into worktrees (transient, not part of the project)
/attachments/

# Claude Code worker PID file (written by scripts/claude-worker.ts on startup)
.primordia-worker.pid

# Generated OpenAPI spec — run `bun run generate-api-docs` to rebuild
/public/openapi.json

# Structured session event log written to each worktree during Claude sessions
.primordia-session.ndjson
