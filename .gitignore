# Dependencies
/node_modules
/.pi/npm/
/.pi/tasks/
/.pnp
.pnp.js
.yarn/install-state.gz

# Next.js build output
/.next/
/out/

# Production build
/build

# Environment files — never commit secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Debug logs
bun-debug.log*
bun-error.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts


# Local SQLite database (passkey auth — local dev only)
*.db
*.db-shm
*.db-wal

# Uploaded attachments copied into worktrees (transient, not part of the project)
/attachments/

# PID files (worker, warmup build, etc.)
*.pid

# Generated OpenAPI spec and types — run `bun run generate:api-types` to rebuild
/public/openapi.json
/lib/api-types.ts
/.openapi-gen/

# Structured session event log written to each worktree during Claude sessions
.primordia-session.ndjson

# Typecheck error snapshot written by the evolve pipeline
.primordia-typecheck-errors.txt

# Playwright
tests/.auth/
tests/.tmp-attachments/
test-results/
playwright-report/
.playwright/
