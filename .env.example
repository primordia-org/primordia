# Copy this file to .env.local and fill in the values

# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# GitHub token with repo + issues write permissions
# Used to create issues when users submit "evolve" requests
# Scopes needed: repo (or public_repo for public repos)
GITHUB_TOKEN=ghp_...

# The GitHub repo this app lives in, e.g. "myusername/primordia"
GITHUB_REPO=owner/primordia

# The label that triggers the evolve GitHub Actions workflow
# Must exist in the repo: https://github.com/owner/primordia/labels
EVOLVE_LABEL=primordia-evolve

# Neon PostgreSQL connection string (for Vercel production)
# Not needed for local development — bun:sqlite is used automatically
# DATABASE_URL=postgresql://...
