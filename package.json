{
  "name": "primordia",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "bun --bun ./node_modules/next/dist/bin/next dev --turbopack",
    "build": "bun --bun ./node_modules/next/dist/bin/next build",
    "start": "bun --bun ./node_modules/next/dist/bin/next start",
    "lint": "eslint .",
    "typecheck": "bun --bun ./node_modules/next/dist/bin/next typegen && tsc --noEmit",
    "deploy-to-exe.dev": "bash scripts/deploy-to-exe-dev.sh",
    "rollback": "bun scripts/rollback.ts",
    "proxy": "bun scripts/reverse-proxy.ts",
    "generate-api-docs": "next-openapi-gen generate --config openapi-gen.config.json",
    "regenerate:model-registry": "bun run scripts/regenerate-model-registry.ts",
    "set-preview-url": "bun scripts/set-preview-url.ts",
    "progress": "bun scripts/progress-monitor.ts",
    "primordia": "bun scripts/primordia.ts",
    "export-branch-parentage-mermaid": "bun scripts/export-branch-parentage-mermaid.ts",
    "export-branch-graph-ascii": "bun scripts/export-branch-graph-ascii.ts",
    "export-branch-graph-unicode": "bun scripts/export-branch-graph-unicode.ts",
    "test:unit": "bun test tests/*.test.ts",
    "test:e2e": "bunx playwright test",
    "test:e2e:headed": "bunx playwright test --headed"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.141",
    "@anthropic-ai/sdk": "^0.96.0",
    "@earendil-works/pi-coding-agent": "0.79.4",
    "@openai/codex": "0.130.0",
    "@scalar/api-reference-react": "^0.9.38",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@zumer/snapdom": "^2.8.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "minimatch": "^10.2.5",
    "mnemonic-id": "^4.1.0",
    "next": "16.2.6",
    "next-openapi-gen": "^1.0.7",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "streamdown": "^2.5.0",
    "swc-plugin-component-annotate": "^1.14.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^11.1.1",
    "web-push": "^3.6.7"
  },
  "overrides": {
    "@babel/core": "^7.29.1",
    "basic-ftp": "^6.0.1",
    "dompurify": "^3.4.11",
    "undici": "^8.5.0",
    "fast-uri": "^3.1.2",
    "fast-xml-builder": "^1.2.0",
    "hono": "^4.12.25",
    "ip-address": "^10.2.0",
    "js-yaml": "^4.2.0",
    "mermaid": "^11.15.0",
    "postcss": "^8.5.14",
    "protobufjs": "^8.5.1",
    "uuid": "^11.1.1",
    "ws": "^8.21.0",
    "qs": "^6.15.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@socketsecurity/bun-security-scanner": "^1.1.2",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^11.0.0",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
